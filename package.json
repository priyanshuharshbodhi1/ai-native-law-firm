{
  "name": "nda-builder-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lawyer-in-the-loop NDA drafting and agreement review agent.",
  "scripts": {
    "dev": "bun src/cli.ts draft samples/draft-input.json",
