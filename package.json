    "test": "vitest run"
  },
  "dependencies": {
    "@mastra/core": "^1.42.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.34",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
